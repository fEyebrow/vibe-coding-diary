---
import { t, type Lang } from '../i18n/utils';

interface Props {
  title: string;
  date: Date;
  summary: string;
  href: string;
  lang: Lang;
  logType?: string;
}

const { title, date, summary, href, lang, logType = 'SYS.LOG' } = Astro.props;
const dateStr = date.toISOString().slice(0, 10).replace(/-/g, '.');
---
<li class="post-item">
  <span class="meta-text post-date">{logType} / {dateStr}</span>
  <a href={href}>
    <h3 class="post-title">{title}</h3>
  </a>
  <p class="post-excerpt">{summary}</p>
  <a href={href} class="read-more mono meta-text">{t('post.read', lang)}</a>
</li>
