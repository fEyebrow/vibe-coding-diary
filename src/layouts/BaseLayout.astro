---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'zh' | 'en';
  ogType?: string;
}

const { title, description, lang, ogType = 'website' } = Astro.props;
---
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <link rel="alternate" hreflang="zh" href={`${Astro.site}zh/`} />
  <link rel="alternate" hreflang="en" href={`${Astro.site}en/`} />
  <link rel="alternate" hreflang="x-default" href={`${Astro.site}zh/`} />
  <link rel="alternate" type="application/rss+xml" title={`Vibe Coding Diary (${lang})`} href={`/${lang}/rss.xml`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Noto+Serif+SC:wght@300;400;600&display=swap" rel="stylesheet" />
  <ClientRouter />
  <script is:inline>
    function applyTheme() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
    }
    applyTheme();
    document.addEventListener('astro:after-swap', applyTheme);
  </script>
</head>
<body>
  <div class="page-wrapper">
    <Header lang={lang} />
    <slot />
    <Footer />
  </div>
</body>
</html>
